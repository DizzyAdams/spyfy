# SpyFy — variaveis de ambiente
# Copie para `.env` e PREENCHA. NUNCA comite o `.env` real (ja esta no .gitignore).

# --- API (FastAPI) ---
# OBRIGATORIO em producao: use um segredo forte, NAO deixe 'dev'.
WEBHOOK_SECRET=
NOVU_API_KEY=
NTFY_URL=https://ntfy.spyfy.io

# --- Auth do tunel (basic auth a frente do web) ---
BASIC_AUTH_USER=spyfy
# Senha forte; esta e a "PS" que protege o acesso publico pelo tunel.
BASIC_AUTH_PASSWORD=

# --- Cloud tunnel ---
# Cloudflare Tunnel: token do tunel (domonio fixo se configurado na CF).
CLOUDFLARE_TUNNEL_TOKEN=
# ngrok: authtoken da conta.
NGROK_AUTHTOKEN=
